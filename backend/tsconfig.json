{
  "compilerOptions": {
    "baseUrl": ".",
    "paths": {
    "@shared/*": ["../shared/*"]
    },
    "target": "ES2020",
    "module": "commonjs",
    "lib": ["ES2020"],
    "outDir": "./dist",
    //"rootDir": "./src",
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "allowImportingTsExtensions": true,
    "moduleResolution": "node"
  },
  "include": ["src/**/*", "../shared/**/*"],
  "exclude": ["node_modules"]
}
